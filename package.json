{
  "name": "social-media-template-automation",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:server": "node server/index.js",
    "dev:all": "concurrently \"npm run dev:server\" \"npm run dev\"",
    "build": "vite build",
    "preview": "vite preview",
    "browsers:install": "puppeteer browsers install chrome",
    "postinstall": "puppeteer browsers install chrome",
    "db:setup": "mysql -u root -p < server/schema.sql",
    "db:migrate": "node server/migrate.js",
    "db:reset": "node server/migrate.js --fresh",
    "db:seed-templates": "node scripts/seed-templates-to-db.mjs",
    "cron": "node server/cron.js",
    "cron:expire": "node server/jobs/expireSubscriptions.js"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "puppeteer": "^25.3.0",
    "vite": "^6.0.0"
  },
  "dependencies": {
    "@codemirror/lang-html": "^6.4.11",
    "axios": "^1.18.1",
    "bcryptjs": "^3.0.2",
    "codemirror": "^6.0.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "exceljs": "^3.4.0",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "jszip": "^3.10.1",
    "multer": "^2.2.0",
    "mysql2": "^3.12.0",
    "node-cron": "^3.0.3"
  }
}
