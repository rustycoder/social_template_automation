{
  "name": "social-template-backend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "node src/index.js",
    "dev:watch": "node --watch-path=src/index.js --watch-path=src/routes --watch-path=src/services --watch-path=src/middleware --watch-path=src/jobs --watch-path=src/database --watch-path=src/config.js --watch-path=src/cron.js --watch-path=src/payment-gateway src/index.js",
    "start": "node src/index.js",
    "db:setup": "mysql -u root -p < src/database/schema.sql",
    "db:migrate": "node src/database/migrate.js",
    "db:reset": "node src/database/migrate.js --fresh",
    "db:seed": "node src/database/seeder/index.js",
    "cron": "node src/cron.js",
    "cron:expire": "node src/jobs/expireSubscriptions.js"
  },
  "dependencies": {
    "axios": "^1.18.1",
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.2.0",
    "mysql2": "^3.12.0",
    "node-cron": "^3.0.3"
  }
}
