{
  "name": "social-media-template-automation",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:server": "node server/index.js",
    "dev:all": "concurrently \"npm run dev:server\" \"npm run dev\"",
    "build": "vite build",
    "preview": "vite preview",
    "db:setup": "mysql -u root -p < server/schema.sql",
    "db:migrate": "node server/migrate.js",
    "db:reset": "node server/migrate.js --fresh"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "vite": "^6.0.0"
  },
  "dependencies": {
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "mysql2": "^3.12.0",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.9",
    "@codemirror/theme-one-dark": "^6.1.2",
    "codemirror": "^6.0.1",
    "exceljs": "^3.4.0",
    "html2pdf.js": "^0.14.0",
    "jszip": "^3.10.1"
  }
}
