# Copy to .env and fill in your values:
# cp .env.example .env

# MPGS gateway credentials (Merchant Administration portal)
MPGS_MERCHANT_ID=your_merchant_id
MPGS_API_PASSWORD=your_api_password

# MPGS REST API version (default: 74)
MPGS_API_VERSION=74

# Gateway region: TEST | NA | AP | EU
MPGS_REGION=TEST

# Example Express server
PORT=3000
