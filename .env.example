# MariaDB / MySQL (target: MariaDB 5.2.2 compatible)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=social_template_automation

# API
PORT=3001
JWT_SECRET=50659cfbd1931c2e90a52f01d9ca7b6ee588da17f90dbcff228ade70d45eedc89de45cafb63b28e356b3afeca01c60083052228a3db05c6aae2fac2d58cddd5e
JWT_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:3000

# Admin seed (used by npm run db:seed)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-admin-password

# Optional absolute path for rendered post images (default: backend/uploads)
# UPLOADS_DIR=

# Cron (subscription expiry)
# Runs every hour by default. Examples:
#   0 * * * *     — every hour
#   */15 * * * *  — every 15 minutes
#   0 0 * * *     — daily at midnight
CRON_EXPIRE_SCHEDULE=0 * * * *

# App URL (used for MPGS payment return redirect)
APP_URL=http://localhost:3000

# MPGS Hosted Checkout (Mastercard Payment Gateway)
MPGS_MERCHANT_ID=your_merchant_id
MPGS_API_PASSWORD=your_api_password
MPGS_API_VERSION=74
MPGS_REGION=TEST
MPGS_CURRENCY=USD
MPGS_MERCHANT_NAME=Social Media Template Automation

# OAuth App Credentials
OAUTH_REDIRECT_BASE=http://localhost:3001/api/social-connections/callback

OAUTH_FB_CLIENT_ID=your_facebook_client_id
OAUTH_FB_CLIENT_SECRET=your_facebook_client_secret

OAUTH_LI_CLIENT_ID=your_linkedin_client_id
OAUTH_LI_CLIENT_SECRET=your_linkedin_client_secret

OAUTH_YT_CLIENT_ID=your_google_youtube_client_id
OAUTH_YT_CLIENT_SECRET=your_google_youtube_client_secret

OAUTH_TT_CLIENT_ID=your_tiktok_client_id
OAUTH_TT_CLIENT_SECRET=your_tiktok_client_secret
